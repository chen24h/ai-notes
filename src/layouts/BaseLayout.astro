---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "AI Infra and agent engineering notes, curated with explicit evidence and factual boundaries.",
} = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const withBase = (path) => `${baseUrl}${path.replace(/^\//, "")}`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand" href={withBase("/")}>
          <span class="brand-mark">TT</span>
          <span class="brand-copy">
            <strong>Tower Notes</strong>
            <small>Facts first, then judgment.</small>
          </span>
        </a>
        <nav class="site-nav" aria-label="Main navigation">
          <a href={withBase("/")}>首页</a>
          <a href={withBase("/posts")}>文章</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <p>Built for compounding knowledge, not content spam.</p>
      </footer>
    </div>
  </body>
</html>
