---
interface HeadingItem {
  id: string;
  text: string;
  level: number;
}

interface Props {
  headings: HeadingItem[];
}

const { headings } = Astro.props;
const groups = headings.reduce(
  (acc, heading) => {
    if (heading.level === 4 && acc.length > 0) {
      acc[acc.length - 1].children.push(heading);
      return acc;
    }

    acc.push({ ...heading, children: [] as HeadingItem[] });
    return acc;
  },
  [] as Array<HeadingItem & { children: HeadingItem[] }>,
);
---

{groups.length > 0 ? (
  <aside class="toc-panel panel" aria-label="Table of contents">
    <p class="eyebrow">On This Page</p>
    <nav class="toc-nav">
      <ol class="toc-list">
        {groups.map((heading) => (
          <li
            class={`toc-item toc-level-${heading.level}`}
            data-toc-group={heading.id}
          >
            <a href={`#${heading.id}`} data-toc-link={heading.id}>
              {heading.text}
            </a>
            {heading.children.length > 0 ? (
              <ol class="toc-children">
                {heading.children.map((child) => (
                  <li class={`toc-item toc-level-${child.level}`}>
                    <a href={`#${child.id}`} data-toc-link={child.id}>
                      {child.text}
                    </a>
                  </li>
                ))}
              </ol>
            ) : null}
          </li>
        ))}
      </ol>
    </nav>
  </aside>
) : null}

<script define:vars={{ headings }} is:inline>
  (() => {
    const initToc = () => {
      if (!Array.isArray(headings) || headings.length === 0) return;

      const articleBody = document.querySelector(".article-body");
      const tocRoot = document.querySelector(".toc-panel");
      if (!articleBody || !tocRoot) return;

      const headingNodes = Array.from(
        articleBody.querySelectorAll("h2, h3, h4"),
      );

      headingNodes.forEach((node, index) => {
        const item = headings[index];
        if (!item) return;
        node.id = item.id;
        node.setAttribute("data-toc-heading", item.id);
      });

      const links = Array.from(
        tocRoot.querySelectorAll("[data-toc-link]"),
      );
      const groups = Array.from(
        tocRoot.querySelectorAll("[data-toc-group]"),
      );

      const setActive = (id) => {
        links.forEach((link) => {
          const active = link.getAttribute("data-toc-link") === id;
          link.classList.toggle("is-active", active);
          if (active) {
            link.setAttribute("aria-current", "true");
          } else {
            link.removeAttribute("aria-current");
          }
        });

        groups.forEach((group) => group.classList.remove("is-expanded"));
        const activeLink = tocRoot.querySelector(`[data-toc-link="${id}"]`);
        const activeGroup = activeLink?.closest("[data-toc-group]");
        if (activeGroup) activeGroup.classList.add("is-expanded");
      };

      if (headingNodes[0]?.id) setActive(headingNodes[0].id);

      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

          if (visible[0]?.target?.id) {
            setActive(visible[0].target.id);
          }
        },
        {
          rootMargin: "-20% 0px -65% 0px",
          threshold: [0, 1],
        },
      );

      headingNodes.forEach((node) => observer.observe(node));
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initToc, { once: true });
    } else {
      initToc();
    }
  })();
</script>
