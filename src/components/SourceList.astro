---
interface Source {
  title: string;
  publisher: string;
  url: string;
  accessedAt: string;
  note?: string;
}

interface Props {
  sources: Source[];
}

const { sources } = Astro.props;
---

<section class="panel">
  <div class="section-heading">
    <p class="eyebrow">Sources</p>
    <h2>原始来源</h2>
  </div>
  <ol class="source-list">
    {
      sources.map((source) => (
        <li>
          <a href={source.url} target="_blank" rel="noreferrer">{source.title}</a>
          <p>
            {source.publisher} · accessed {source.accessedAt}
            {source.note ? ` · ${source.note}` : ""}
          </p>
        </li>
      ))
    }
  </ol>
</section>
