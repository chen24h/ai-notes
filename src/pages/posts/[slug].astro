---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import FactLedger from "../../components/FactLedger.astro";
import SourceList from "../../components/SourceList.astro";
import TableOfContents from "../../components/TableOfContents.astro";

const stripTags = (input: string) =>
  input
    .replace(/<[^>]+>/g, "")
    .replace(/&amp;/g, "&")
    .replace(/&lt;/g, "<")
    .replace(/&gt;/g, ">")
    .replace(/&#39;/g, "'")
    .replace(/&quot;/g, '"')
    .trim();

const slugify = (input: string) =>
  input
    .toLowerCase()
    .normalize("NFKD")
    .replace(/[^\p{Letter}\p{Number}\s-]/gu, "")
    .trim()
    .replace(/\s+/g, "-");

const extractHeadings = (body: string) => {
  const items: { text: string; level: number }[] = [];
  const bodyWithoutCode = body.replace(/~~~[\s\S]*?~~~/g, "");

  const headingPattern = /^(##{1,3})\s+(.+)$|<h([2-4])[^>]*>([\s\S]*?)<\/h\3>/gm;
  let match;
  while ((match = headingPattern.exec(bodyWithoutCode)) !== null) {
    if (match[1] && match[2]) {
      items.push({
        level: match[1].length,
        text: stripTags(match[2]),
      });
      continue;
    }

    if (match[3] && match[4]) {
      items.push({
        level: Number(match[3]),
        text: stripTags(match[4]),
      });
    }
  }

  const counts = new Map<string, number>();
  return items.map((item) => {
    const base = slugify(item.text) || `section-${item.level}`;
    const seen = counts.get(base) ?? 0;
    counts.set(base, seen + 1);
    return {
      ...item,
      id: seen === 0 ? base : `${base}-${seen + 1}`,
    };
  });
};

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => data.status === "published");

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const headings = extractHeadings(post.body);
---

<BaseLayout title={`${post.data.title} | Tower Notes`} description={post.data.summary}>
  <article class="article-shell">
    <header class="article-header">
      <p class="eyebrow">{post.data.category}</p>
      <h1>{post.data.title}</h1>
      <p class="article-summary">{post.data.summary}</p>
      <div class="article-meta">
        <span>Published {post.data.publishedAt.toLocaleDateString("zh-CN")}</span>
        {post.data.updatedAt ? (
          <span>Updated {post.data.updatedAt.toLocaleDateString("zh-CN")}</span>
        ) : null}
      </div>
      <div class="tag-row">
        {post.data.tags.map((tag) => <span class="tag">#{tag}</span>)}
      </div>
    </header>

    <div class="article-layout">
      <TableOfContents headings={headings} />

      <div class="article-main">
        <section class="article-body panel prose">
          <div class="callout">
            <p class="eyebrow">Truth Standard</p>
            <p>{post.data.truthStandard}</p>
          </div>
          <div class="callout">
            <p class="eyebrow">Core Thesis</p>
            <p>{post.data.thesis}</p>
          </div>
          <Content />
        </section>

        <FactLedger facts={post.data.facts} />
        <SourceList sources={post.data.sources} />
      </div>
    </div>
  </article>
</BaseLayout>
